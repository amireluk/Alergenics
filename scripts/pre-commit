#!/bin/bash
# Auto-bump patch version on every commit
# Updates: package.json, index.html (version-tag + copyright line)

PACKAGE="package.json"
INDEX="index.html"

# Read current version from package.json
CURRENT=$(grep -oP '"version":\s*"\K[^"]+' "$PACKAGE")
if [ -z "$CURRENT" ]; then
    echo "pre-commit: could not read version from $PACKAGE"
    exit 1
fi

# Split into major.minor.patch
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="${MAJOR}.${MINOR}.${NEW_PATCH}"

# Check if version was already manually bumped in this commit
STAGED_VERSION=$(git diff --cached -- "$PACKAGE" | grep -oP '^\+.*"version":\s*"\K[^"]+' || true)
if [ -n "$STAGED_VERSION" ] && [ "$STAGED_VERSION" != "$CURRENT" ]; then
    # Already bumped manually — skip auto-bump
    exit 0
fi

# Bump in package.json
sed -i "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PACKAGE"

# Bump in index.html (version-tag span and copyright line)
sed -i "s/v${CURRENT}/v${NEW_VERSION}/g" "$INDEX"

# Stage the updated files
git add "$PACKAGE" "$INDEX"

echo "pre-commit: auto-bumped version $CURRENT → $NEW_VERSION"
